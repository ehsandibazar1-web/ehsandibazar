{
    "name": "laravel/laravel",
    "description": "The Laravel Framework.",
    "keywords": ["framework", "laravel"],
    "license": "MIT",
    "type": "project",
    "require": {
        "php": "^7.1.3",
        "arcanedev/log-viewer": "*",
        "artesaos/seotools": "*",
        "carlos-meneses/laravel-mpdf": "^2.1",
        "cviebrock/eloquent-sluggable": "*",
        "fideloper/proxy": "*",
        "overtrue/laravel-like": "^4.0",
        "fruitcake/laravel-cors": "^2.2",
        "hekmatinasser/verta": "*",
        "iatstuti/laravel-cascade-soft-deletes": "*",
        "ipecompany/smsirlaravel": "^1.0",
        "laravel/framework": "7.*",
        "laravel/helpers": "^1.5",
        "laravel/tinker": "*",
        "laravel/ui": "^2.0",
        "league/flysystem-aws-s3-v3": "~1.0",
        "league/flysystem-sftp": "~1.0",
        "maatwebsite/excel": "*",
        "laravelium/sitemap": "7.*",
        "realrashid/sweet-alert": "^5.0",
        "shetabit/payment": "^4.2",
        "spatie/laravel-image-optimizer": "^1.6",
        "spatie/pdf-to-image": "^2.1",
        "unisharp/laravel-filemanager": "^2.1",
        "werneckbh/laravel-qr-code": "*",
        "willvincent/laravel-rateable": "*",
        "yadahan/laravel-authentication-log": "^1.5",
        "anhskohbo/no-captcha": "^3.3",
        "yajra/laravel-datatables-oracle": "~9.0"
    },
    "require-dev": {
        "filp/whoops": "*",
        "fzaninotto/faker": "*",
        "mockery/mockery": "*",
        "nunomaduro/collision": "*",
        "phpunit/phpunit": "*"
    },
    "autoload": {
        "classmap": [
            "database/seeds",
            "database/factories"
        ],
        "files": [
            "app/Helper/Helper.php"
        ],
        "psr-4": {
            "App\\": "app/",
            "Modules\\": "Modules/"


        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "dont-discover": [
            ]
        }
    },
    "scripts": {
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover"
        ]
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
